{
  "name": "scale-workshop",
  "version": "3.2.0-rc4",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "cypress-only": "cypress run --e2e",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "lint-no-fix": "run-s lint-no-fix:*",
    "lint-no-fix:oxlint": "oxlint .",
    "lint-no-fix:eslint": "eslint . --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "harmonic-entropy": "^0.3.1",
    "isomorphic-qwerty": "^0.1.1",
    "ji-lattice": "^0.3.2",
    "jszip": "^3.10.1",
    "moment-of-symmetry": "^0.9.2",
    "pinia": "^3.0.4",
    "qs": "^6.15.0",
    "sonic-weave": "^0.12.1",
    "sw-synth": "^0.3.1",
    "values.js": "^2.1.1",
    "vue": "^3.5.27",
    "vue-router": "^5.0.4",
    "webmidi": "^3.1.16",
    "xen-dev-utils": "^0.12.2",
    "xen-midi": "^0.3.1"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/eslint-plugin": "^1.6.14",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "cypress": "^15.13.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^5.3.0",
    "eslint-plugin-oxlint": "~1.42.0",
    "eslint-plugin-vue": "~10.7.0",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.42.0",
    "prettier": "3.8.1",
    "start-server-and-test": "^2.1.5",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.27.5"
  }
}
